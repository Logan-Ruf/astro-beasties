{
  "name": "astro-beasties",
  "version": "0.1.0",
  "type": "module",
  "description": "Beasties integration for Astro - inline critical CSS during static builds",
  "repository": {
    "type": "git",
    "url": "git@github.com:lruf/astro-beasties.git"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "astro-integration",
    "astro-component",
    "astro",
    "beasties",
    "critters",
    "critical-css",
    "css",
    "performance"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "beasties": "^0.4.1",
    "glob": "^13.0.6",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "astro": "^5.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  }
}
